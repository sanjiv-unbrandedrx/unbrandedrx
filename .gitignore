# =============================================================================
# UnbrandedRx .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Build & output
# -----------------------------------------------------------------------------
/.next/
/out/
/build
/coverage

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env*
*.pem

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editor & IDE files
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Debug logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
.nvmrc

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# AI / Claude Code
# -----------------------------------------------------------------------------
claude.md
.claude/
tmpclaude-*

# -----------------------------------------------------------------------------
# Non-source working directories
# Reference images, archives, research, questionnaires, asset dumps — these
# live locally for team members who need them but don't belong in the repo.
# -----------------------------------------------------------------------------
/archive/
/dump/
/questionnaires/
/research/
/nul
Website Images*/

# Loose images & assets in the repo root (screenshots, design refs, etc.)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.bmp
/*.ico
/*.svg
/*.psd
/*.ai
/*.sketch
/*.fig
/*.pdf
/*.mp4
/*.mov
/*.zip
/*.rar
/*.7z
